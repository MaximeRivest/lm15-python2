{
  "id": "openai.basic_text",
  "provider": "openai",
  "feature": "basic_text",
  "description": "Simple text prompt, no streaming",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Say hello."
            }
          ]
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  },
  "expect_lm15": {
    "parts": {
      "text": {
        "min": 1
      }
    },
    "finish_reason": "stop",
    "usage": {
      "required": true
    }
  }
}
